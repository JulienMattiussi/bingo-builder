# Backend Server Port
PORT=3001

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/bingo-builder

# MongoDB Test Database URI (used for E2E tests)
MONGODB_TEST_URI=mongodb://localhost:27018/bingo-test

# Frontend Configuration (Vite requires VITE_ prefix)
VITE_API_PORT=3001
VITE_PORT=3000

# Application Limits
CARD_TITLE_MAX_LENGTH=25
TILE_MAX_LENGTH=40
PLAYER_NAME_MAX_LENGTH=10
MAX_PLAYERS_PER_CARD=6

# Frontend Application Limits (VITE_ prefix for client-side access)
VITE_CARD_TITLE_MAX_LENGTH=25
VITE_TILE_MAX_LENGTH=40
VITE_PLAYER_NAME_MAX_LENGTH=10
VITE_MAX_PLAYERS_PER_CARD=6
